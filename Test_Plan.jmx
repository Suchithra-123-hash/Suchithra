                  <stringProp name="parameters"></stringProp>
                  <stringProp name="script">
// File path
def path = &quot;C:/Users/srisu/OneDrive/Desktop/jmeter/document1/FundTransfer_Result.txt&quot;

// Create file object
def file = new File(path)

// ✅ Create folder if not exists
file.getParentFile().mkdirs()

// ✅ Create file if not exists
if(!file.exists()){
    file.createNewFile()
}

// Get JMeter variables
def bal = vars.get(&quot;C_balance&quot;)
def amt = vars.get(&quot;TransferAmt&quot;)

// Write values into file
file.append(&quot;Balance=&quot; + bal + &quot; | Amount=&quot; + amt + &quot;\n&quot;)</stringProp>
                  <stringProp name="scriptLanguage">groovy</stringProp>
